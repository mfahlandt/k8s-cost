# k8s-cost secrets template. Copy to .env and fill in. .env is gitignored.
#   cp .env.example .env && $EDITOR .env
#   set -a; source .env; set +a      # load into your shell before collecting
#
# For CI / production, move these into GitHub Actions secrets or a secret
# manager instead of a local file.

# DigitalOcean billing API token (scope: billing:read)
DIGITALOCEAN_TOKEN=

# IBM Cloud IAM API key — K8sOnPower account (provider: ibm-power)
IBMCLOUD_API_KEY=

# IBM Cloud IAM API key — K8sOnZ-s390x account (provider: ibm-z)
IBM_Z_API_KEY=
IBM_Z_ACCOUNT_ID=6efe35b964de46b0924c2e95fe410903

# Fastly API token (scope: stats/global:read) — used for bandwidth usage
FASTLY_API_TOKEN=

# Slack incoming webhook URL for budget alerts
SLACK_WEBHOOK_URL=

# AWS uses the standard credential chain (profile "k8s" or env vars), not this
# file. GCP uses gcloud ADC. See docs/DATA_SOURCES.md.

# AWS: uses the standard chain — put credentials in ~/.aws/credentials
# (aws configure --profile k8s) and set:
AWS_PROFILE=k8s
# GCP: uses gcloud ADC (gcloud auth application-default login), or a
# service-account key for CI:
GOOGLE_CLOUD_PROJECT=kubernetes-public
#GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
